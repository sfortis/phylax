<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) backup/restore and device transfer rules.
    Mirrors backup_rules.xml: exclude encrypted/device-bound state.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="frigate_secrets.xml"/>
        <exclude domain="sharedpref" path="frigate_secrets_fallback.xml"/>
        <exclude domain="sharedpref" path="com.asksakis.freegate_preferences.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="frigate_secrets.xml"/>
        <exclude domain="sharedpref" path="frigate_secrets_fallback.xml"/>
        <exclude domain="sharedpref" path="com.asksakis.freegate_preferences.xml"/>
    </device-transfer>
</data-extraction-rules>
