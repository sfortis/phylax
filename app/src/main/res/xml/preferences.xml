<?xml version="1.0" encoding="utf-8"?>
<!--
    Root settings screen. Each top-level <PreferenceScreen> becomes a clickable
    drill-down entry handled by PreferenceFragmentCompat out of the box — no custom
    navigation, back-press, or fragment swapping needed.
-->
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceScreen
        android:key="cat_connection"
        android:title="Connection"
        android:summary="URLs, network mode, account, mTLS"
        app:iconSpaceReserved="false">

        <PreferenceCategory
            android:title="URLs"
            app:iconSpaceReserved="false">

            <EditTextPreference
                android:key="internal_url"
                android:selectAllOnFocus="true"
                android:singleLine="true"
                android:title="Internal URL"
                android:summary="URL when on home network"
                android:defaultValue="http://192.168.1.100:5000"
                android:inputType="textUri|textNoSuggestions"
                android:importantForAutofill="no"
                app:iconSpaceReserved="false" />

            <EditTextPreference
                android:defaultValue="https://demo.frigate.video/"
                android:importantForAutofill="no"
                android:inputType="textUri|textNoSuggestions"
                android:key="external_url"
                android:selectAllOnFocus="true"
                android:singleLine="true"
                android:summary="URL when not on home network"
                android:title="External URL"
                app:iconSpaceReserved="false" />
        </PreferenceCategory>

        <PreferenceCategory
            android:title="Network Mode"
            app:iconSpaceReserved="false">

            <ListPreference
                android:key="connection_mode"
                android:title="Connection Mode"
                android:summary="Select which URL to use"
                android:entries="@array/connection_mode_entries"
                android:entryValues="@array/connection_mode_values"
                android:defaultValue="auto"
                app:iconSpaceReserved="false" />

            <Preference
                android:key="current_wifi_status"
                android:title="Current Status"
                android:summary="Checking network status..."
                app:iconSpaceReserved="false" />

            <MultiSelectListPreference
                android:key="home_wifi_networks"
                android:title="Home WiFi Networks"
                android:summary="Networks treated as home"
                android:dialogTitle="Select home networks"
                app:iconSpaceReserved="false" />

            <Preference
                android:key="add_home_network"
                android:title="Add a home network"
                android:summary="Enter a WiFi SSID manually"
                app:iconSpaceReserved="false" />

        </PreferenceCategory>

        <PreferenceCategory
            android:title="Frigate Account"
            app:iconSpaceReserved="false">

            <EditTextPreference
                android:key="frigate_username"
                android:title="Username"
                android:summary="Frigate UI username"
                android:inputType="text|textNoSuggestions"
                android:singleLine="true"
                android:importantForAutofill="no"
                app:iconSpaceReserved="false" />

            <EditTextPreference
                android:key="frigate_password"
                android:title="Password"
                android:summary="Frigate UI password (stored encrypted)"
                android:inputType="textPassword"
                android:singleLine="true"
                android:importantForAutofill="no"
                app:iconSpaceReserved="false" />

            <Preference
                android:key="client_cert_alias"
                android:title="Client certificate (mTLS)"
                android:summary="Not selected"
                app:iconSpaceReserved="false" />

            <SwitchPreferenceCompat
                android:key="strict_tls_external"
                android:title="Strict TLS on external URL"
                android:summary="Require a trusted certificate for the public URL. Disable if your Frigate uses a self-signed cert."
                android:defaultValue="false"
                app:iconSpaceReserved="false" />

        </PreferenceCategory>

    </PreferenceScreen>

    <PreferenceScreen
        android:key="cat_notifications"
        android:title="Notifications"
        android:summary="Alerts, cameras, background listener"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="notifications_enabled"
            android:title="Enable notifications"
            android:summary="Listen for Frigate alerts in the background"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="notify_alerts"
            android:title="Alerts"
            android:summary="Reviews flagged by Frigate as alerts"
            android:defaultValue="true"
            android:dependency="notifications_enabled"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="notify_detections"
            android:title="Detections"
            android:summary="All tracked-object reviews (noisier)"
            android:defaultValue="false"
            android:dependency="notifications_enabled"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="notify_cameras"
            android:title="Cameras"
            android:summary="All cameras"
            android:dependency="notifications_enabled"
            app:iconSpaceReserved="false" />

        <ListPreference
            android:key="notify_tap_action"
            android:title="Tap action"
            android:summary="What happens when you tap a notification"
            android:entries="@array/notify_tap_action_entries"
            android:entryValues="@array/notify_tap_action_values"
            android:defaultValue="review"
            android:dependency="notifications_enabled"
            app:iconSpaceReserved="false" />

        <ListPreference
            android:key="notify_cooldown_global"
            android:title="Global cooldown"
            android:defaultValue="0"
            android:entries="@array/cooldown_entries"
            android:entryValues="@array/cooldown_values"
            android:dependency="notifications_enabled"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <ListPreference
            android:key="notify_cooldown_camera"
            android:title="Per-camera cooldown"
            android:defaultValue="0"
            android:entries="@array/cooldown_entries"
            android:entryValues="@array/cooldown_values"
            android:dependency="notifications_enabled"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="battery_optimization"
            android:title="Battery optimization"
            android:summary="Required so the listener stays alive in the background"
            android:dependency="notifications_enabled"
            app:iconSpaceReserved="false" />

    </PreferenceScreen>

    <PreferenceScreen
        android:key="cat_downloads"
        android:title="Downloads"
        android:summary="Where videos and images are saved"
        app:iconSpaceReserved="false">

        <ListPreference
            android:key="download_location"
            android:title="Download Location"
            android:summary="Choose where to save downloaded videos and images"
            android:entries="@array/download_location_entries"
            android:entryValues="@array/download_location_values"
            android:defaultValue="downloads"
            app:iconSpaceReserved="false" />

    </PreferenceScreen>

    <PreferenceScreen
        android:key="cat_advanced"
        android:title="Advanced"
        android:summary="User agent, version, updates"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="use_custom_user_agent"
            android:title="Use custom User Agent"
            android:summary="Enable to set a custom browser User Agent string"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="custom_user_agent"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Custom User Agent"
            android:summary="Browser User Agent string to use"
            android:defaultValue="Mozilla/5.0 (Linux; Android) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/118.0.0.0 Mobile Safari/537.36"
            android:inputType="text|textNoSuggestions"
            android:importantForAutofill="no"
            android:dependency="use_custom_user_agent"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="app_version"
            android:title="App Version"
            android:summary="1.0"
            android:enabled="false"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="check_updates"
            android:title="Check for Updates"
            android:summary="Check for new versions of the app"
            app:iconSpaceReserved="false" />

    </PreferenceScreen>

</PreferenceScreen>
