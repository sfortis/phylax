<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup rules for API < 31. Exclude everything sensitive or device-bound:
    encrypted credentials (can't be decrypted on another device), stored client
    certificate alias, and default prefs that contain URLs/SSIDs/usernames.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="frigate_secrets.xml"/>
    <exclude domain="sharedpref" path="frigate_secrets_fallback.xml"/>
    <exclude domain="sharedpref" path="com.asksakis.freegate_preferences.xml"/>
</full-backup-content>
