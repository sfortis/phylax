<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!--
        Server picker pinned at the top so the user always knows which Frigate
        deployment the rest of this screen edits. The custom rounded layout
        marks the row as a distinct landing zone for the picker; the title is
        bound from ServerProfileStore in [ConnectionSettingsFragment].
    -->
    <Preference
        android:key="active_server"
        android:title="Server"
        android:layout="@layout/pref_server_row"
        app:iconSpaceReserved="false" />

    <PreferenceCategory
        android:title="URLs">

        <!--
            No `android:defaultValue` here on purpose: it would auto-persist
            onto a freshly-created (empty) server profile, defeating the wipe
            that `ServerProfileStore.applyToFlatState` does on profile switch.
        -->
        <EditTextPreference
            android:key="internal_url"
            android:icon="@drawable/ic_conn_internal"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Internal URL"
            android:summary="URL when on home network"
            android:inputType="textUri|textNoSuggestions"
            android:importantForAutofill="no" />

        <EditTextPreference
            android:key="external_url"
            android:icon="@drawable/ic_conn_external"
            android:importantForAutofill="no"
            android:inputType="textUri|textNoSuggestions"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:summary="URL when not on home network"
            android:title="External URL" />
    </PreferenceCategory>

    <PreferenceCategory
        android:title="Network Mode">

        <ListPreference
            android:key="connection_mode"
            android:icon="@drawable/ic_conn_mode"
            android:title="Connection Mode"
            android:summary="Select which URL to use"
            android:entries="@array/connection_mode_entries"
            android:entryValues="@array/connection_mode_values"
            android:defaultValue="auto" />

        <Preference
            android:key="current_wifi_status"
            android:icon="@drawable/ic_conn_wifi"
            android:title="Current Status"
            android:summary="Checking network status..." />

        <MultiSelectListPreference
            android:key="home_wifi_networks"
            android:icon="@drawable/ic_conn_wifi"
            android:title="Home WiFi Networks"
            android:summary="Networks treated as home"
            android:dialogTitle="Select home networks" />

        <Preference
            android:key="add_home_network"
            android:icon="@drawable/ic_conn_wifi_add"
            android:title="Add a home network"
            android:summary="Enter a WiFi SSID manually" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Frigate Account">

        <EditTextPreference
            android:key="frigate_username"
            android:icon="@drawable/ic_conn_account"
            android:title="Username"
            android:summary="Frigate UI username"
            android:inputType="text|textNoSuggestions"
            android:singleLine="true"
            android:autofillHints="username" />

        <EditTextPreference
            android:key="frigate_password"
            android:icon="@drawable/ic_conn_password"
            android:title="Password"
            android:summary="Frigate UI password (stored encrypted)"
            android:inputType="textPassword"
            android:singleLine="true"
            android:autofillHints="password" />

        <Preference
            android:key="client_cert_alias"
            android:icon="@drawable/ic_conn_cert"
            android:title="Client certificate (mTLS)"
            android:summary="Not selected" />

        <SwitchPreferenceCompat
            android:key="strict_tls_external"
            android:icon="@drawable/ic_conn_strict_tls"
            android:title="Strict TLS on external URL"
            android:summary="Require a trusted certificate for the public URL. Disable if your Frigate uses a self-signed cert."
            android:defaultValue="false" />

    </PreferenceCategory>

</PreferenceScreen>
