<?xml version="1.0" encoding="utf-8"?>
<!--
    Top-level Settings screen. Each preference navigates to its own fragment via the
    nav graph so back/up behave naturally (addToBackStack, slide animation, ActionBar
    up-arrow) instead of the old manual screenStack swap.
-->
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <Preference
        android:key="cat_connection"
        android:icon="@drawable/ic_settings_connection"
        android:title="Connection"
        android:summary="URLs, network mode, account, mTLS" />

    <Preference
        android:key="cat_notifications"
        android:icon="@drawable/ic_settings_notifications"
        android:title="Notifications"
        android:summary="Alerts, cameras, background listener" />

    <Preference
        android:key="cat_downloads"
        android:icon="@drawable/ic_settings_downloads"
        android:title="Downloads"
        android:summary="Where videos and images are saved" />

    <Preference
        android:key="cat_advanced"
        android:icon="@drawable/ic_settings_advanced"
        android:title="Advanced"
        android:summary="User agent, version, updates" />

    <Preference
        android:key="cat_about"
        android:icon="@drawable/ic_settings_about"
        android:title="About"
        android:summary="Source code, license, support the project" />

</PreferenceScreen>
