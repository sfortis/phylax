<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <!-- ═══════════ CPU / GPU hero meters ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:id="@+id/stats_cpu_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/stats_card_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CPU"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.12" />

                <TextView
                    android:id="@+id/stats_cpu_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    tools:text="42%" />

                <ProgressBar
                    android:id="@+id/stats_cpu_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progressTint="@color/accent_orange"
                    android:progressBackgroundTint="@color/divider_subtle"
                    tools:progress="42" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/stats_gpu_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/stats_card_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPU"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.12" />

                <TextView
                    android:id="@+id/stats_gpu_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    tools:text="18%" />

                <ProgressBar
                    android:id="@+id/stats_gpu_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progressTint="@color/accent_orange"
                    android:progressBackgroundTint="@color/divider_subtle"
                    tools:progress="18" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══════════ Summary chips (memory / uptime) ═══════════ -->
        <LinearLayout
            android:id="@+id/stats_chip_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/stats_memory_chip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/stats_chip_background"
                android:fontFamily="monospace"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                tools:text="RAM 38%" />

            <TextView
                android:id="@+id/stats_uptime_chip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/stats_chip_background"
                android:fontFamily="monospace"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                tools:text="up 2d 14h" />
        </LinearLayout>

        <!-- ═══════════ Detectors ═══════════ -->
        <TextView
            android:id="@+id/stats_detectors_heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="6dp"
            android:text="Detectors"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.12" />

        <LinearLayout
            android:id="@+id/stats_detectors_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- ═══════════ Cameras ═══════════ -->
        <TextView
            android:id="@+id/stats_cameras_heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="6dp"
            android:text="Cameras"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.12" />

        <LinearLayout
            android:id="@+id/stats_cameras_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Shown when no data yet -->
        <TextView
            android:id="@+id/stats_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Waiting for Frigate..."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
