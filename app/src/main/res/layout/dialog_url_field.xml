<?xml version="1.0" encoding="utf-8"?>
<!--
  Material text-field dialog for the internal/external URL preferences.
  TextInputLayout's error slot is used for input-validation feedback; the
  status TextView underneath shows live probe feedback ("Probing…", "✓ HTTP
  200", "✗ Connection refused") so the two stay visually distinct.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="0dp">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/url_field_input_layout"
        style="@style/Widget.Freegate.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:boxBackgroundMode="outline"
        app:hintAnimationEnabled="true"
        app:errorEnabled="true">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/url_field_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionDone"
            android:singleLine="true"
            android:selectAllOnFocus="true"
            android:inputType="textUri|textNoSuggestions"
            android:importantForAutofill="no" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/url_field_probe_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:visibility="gone" />
</LinearLayout>
