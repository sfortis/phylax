<?xml version="1.0" encoding="utf-8"?>
<!--
  Reusable Material text-field dialog content for the connection account
  preferences. Grey outline + accent floating label; password mode is toggled
  via endIconMode at runtime so the same layout serves username + password.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="0dp">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/account_field_input_layout"
        style="@style/Widget.Freegate.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:boxBackgroundMode="outline"
        app:hintAnimationEnabled="true">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/account_field_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionDone"
            android:singleLine="true"
            android:selectAllOnFocus="true" />
    </com.google.android.material.textfield.TextInputLayout>
</FrameLayout>
