<?xml version="1.0" encoding="utf-8"?>
<!--
    Chromeless top-level layout: the app bar hosts Refresh and Settings as toolbar
    actions top-right, no navigation drawer. The fragment area below fills the rest.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/app_bar_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="#000000"
        android:theme="@style/Theme.Freegate.AppBarOverlay"
        app:statusBarForeground="@android:color/transparent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#000000"
            app:contentInsetStartWithNavigation="0dp"
            app:titleTextColor="#FFFFFF"
            app:titleTextAppearance="@style/ToolbarTitle.Freegate"
            app:popupTheme="@style/Theme.Freegate.PopupOverlay">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Frigate system stats chip (CPU / GPU). Hidden until a stats frame arrives. -->
                <TextView
                    android:id="@+id/stats_cpu_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/stats_cpu_indicator_background"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:textColor="#B0C4D8"
                    android:textSize="10sp"
                    android:visibility="gone"
                    tools:text="CPU 42%"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/stats_gpu_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/stats_gpu_indicator_background"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:textColor="#C8B0D8"
                    android:textSize="10sp"
                    android:visibility="gone"
                    tools:text="GPU 18%"
                    tools:visibility="visible" />

                <!-- Network indicator -->
                <TextView
                    android:id="@+id/network_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:background="@drawable/network_indicator_background"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="INT"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment_content_main"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        app:navGraph="@navigation/mobile_navigation" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
