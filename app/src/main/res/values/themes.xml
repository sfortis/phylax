<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
        Material 3 base theme mapped onto the app's human-readable palette (colors.xml).
        Each `colorXxx` Material role is bound to a named color so you can change the
        look in one place without memorising the MD3 token names.
    -->
    <style name="Theme.Freegate" parent="Theme.Material3.DayNight">
        <!-- Brand accent: switches, sliders, focus rings -->
        <item name="colorPrimary">@color/accent_orange</item>
        <item name="colorOnPrimary">@color/accent_orange_on</item>
        <item name="colorPrimaryContainer">@color/accent_orange_container</item>
        <item name="colorOnPrimaryContainer">@color/accent_orange_container_on</item>

        <item name="colorSecondary">@color/accent_orange_alt</item>
        <item name="colorOnSecondary">@color/accent_orange_alt_on</item>
        <item name="colorSecondaryContainer">@color/accent_orange_strong</item>
        <item name="colorOnSecondaryContainer">@color/accent_orange_strong_on</item>

        <!-- Surfaces -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>

        <!-- Text: primary = labels/titles; secondary = descriptions/subtitles -->
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Dividers/outlines -->
        <item name="colorOutline">@color/divider</item>
        <item name="colorOutlineVariant">@color/divider_subtle</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Freegate.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Freegate.AppBarOverlay" parent="ThemeOverlay.Material3.Dark" />
    <style name="Theme.Freegate.PopupOverlay" parent="ThemeOverlay.Material3.Light" />

    <!--
        Toolbar title in Goldman, noticeably smaller than the Material3 default (22sp).
        Matches the massdroid-native look used on the other app.
    -->
    <!--
        Shared Material3 dialog theme for all in-app popups (stats, connection status,
        future confirms). Flat dark grey panel + Goldman-agnostic defaults so the app's
        chrome stays consistent across destinations.
    -->
    <style name="ThemeOverlay.Freegate.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">#1A1A1A</item>
        <item name="colorSurfaceVariant">#1A1A1A</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:background">#1A1A1A</item>
    </style>

    <!--
        Neutral toolbar title text appearance. The brand font (Ancient-God) is applied
        programmatically in MainActivity only on the root destination; Settings / child
        screens keep sans-serif-medium from this baseline.
    -->
    <style name="ToolbarTitle.Freegate" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">18sp</item>
    </style>

</resources>
