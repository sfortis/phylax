<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
        Material 3 base theme mapped onto the app's human-readable palette (colors.xml).
        Each `colorXxx` Material role is bound to a named color so you can change the
        look in one place without memorising the MD3 token names.
    -->
    <style name="Theme.Freegate" parent="Theme.Material3.DayNight">
        <!-- Brand accent: switches, sliders, focus rings -->
        <item name="colorPrimary">@color/accent_orange</item>
        <item name="colorOnPrimary">@color/accent_orange_on</item>
        <item name="colorPrimaryContainer">@color/accent_orange_container</item>
        <item name="colorOnPrimaryContainer">@color/accent_orange_container_on</item>

        <!--
            Secondary == primary container variant. We deliberately collapse
            the MD3 secondary slot onto the same brand accent because the app
            uses a single-hue identity; Material's two-token system is overkill
            for a focused-purpose tool app like this.
        -->
        <item name="colorSecondary">@color/accent_orange_container</item>
        <item name="colorOnSecondary">@color/accent_orange_container_on</item>
        <item name="colorSecondaryContainer">@color/accent_orange_container</item>
        <item name="colorOnSecondaryContainer">@color/accent_orange_container_on</item>

        <!-- Surfaces -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>

        <!-- Text: primary = labels/titles; secondary = descriptions/subtitles -->
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Dividers/outlines -->
        <item name="colorOutline">@color/divider</item>
        <item name="colorOutlineVariant">@color/divider_subtle</item>

        <!--
            Decouple SwitchPreferenceCompat from the brand accent so a screen
            full of toggles doesn't shout in orange. Material 3 SwitchCompat
            ignores `colorControlActivated` and binds its tints to colorPrimary
            internally, so we override the widget's default style instead. The
            tint state-lists resolve through theme attrs (?attr/colorOnSurface,
            ?attr/colorOutline) so re-theming the app keeps switches in sync
            without ever hardcoding a colour value here.
        -->
        <item name="switchStyle">@style/Widget.Freegate.SwitchCompat</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Freegate.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Freegate.AppBarOverlay" parent="ThemeOverlay.Material3.Dark" />
    <style name="Theme.Freegate.PopupOverlay" parent="ThemeOverlay.Material3.Light" />

    <!--
        Toolbar title in Goldman, noticeably smaller than the Material3 default (22sp).
        Matches the massdroid-native look used on the other app.
    -->
    <!--
        Shared Material3 dialog theme for all in-app popups (stats, connection status,
        future confirms). Flat dark grey panel + Goldman-agnostic defaults so the app's
        chrome stays consistent across destinations.
    -->
    <style name="ThemeOverlay.Freegate.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/surface_dialog</item>
        <item name="colorSurfaceVariant">@color/surface_dialog</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:background">@color/surface_dialog</item>
    </style>

    <!--
        Neutral toolbar title text appearance. The brand font (Ancient-God) is applied
        programmatically in MainActivity only on the root destination; Settings / child
        screens keep sans-serif-medium from this baseline.
    -->
    <style name="ToolbarTitle.Freegate" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">18sp</item>
    </style>

    <!--
        TextInputLayout for in-dialog form fields (URL / username / password).
        Grey outline across every state; only the floating label and the cursor
        pick up the brand accent, so the dialog stays calm and the active field
        is signalled by the label alone (no leading icon, no orange box).
    -->
    <!--
        Custom SwitchCompat style with stateful tints expressed in theme tokens.
        Bound from the base theme via `switchStyle`, so SwitchPreferenceCompat
        (which uses SwitchCompat under the hood) picks it up without any
        per-widget XML changes.
    -->
    <style name="Widget.Freegate.SwitchCompat" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="thumbTint">@color/switch_thumb_tint</item>
        <item name="trackTint">@color/switch_track_tint</item>
    </style>

    <style name="Widget.Freegate.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/text_input_box_stroke_state</item>
        <item name="boxStrokeErrorColor">@color/cert_missing</item>
        <item name="hintTextColor">@color/text_input_hint_state</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="cursorColor">@color/accent_orange</item>
        <item name="errorTextColor">@color/cert_missing</item>
    </style>

</resources>
