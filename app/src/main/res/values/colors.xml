<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- Brand accent: orange used for switches, focus rings, interactive controls. -->
    <color name="accent_orange">#FF8F00</color>
    <color name="accent_orange_on">#000000</color>
    <color name="accent_orange_container">#FFB74D</color>
    <color name="accent_orange_container_on">#2B1600</color>

    <color name="accent_orange_alt">#FFA726</color>
    <color name="accent_orange_alt_on">#000000</color>
    <color name="accent_orange_strong">#FF8F00</color>
    <color name="accent_orange_strong_on">#FFFFFF</color>

    <!-- Surfaces: pure black canvas. -->
    <color name="background">#000000</color>
    <color name="surface">#000000</color>
    <color name="surface_variant">#000000</color>

    <!-- Text colors: primary = near-white, secondary = muted grey (used for descriptions). -->
    <color name="text_primary">#E0E0E0</color>
    <color name="text_secondary">#888888</color>

    <!-- Divider/outline lines. -->
    <color name="divider">#666666</color>
    <color name="divider_subtle">#333333</color>

    <!-- Status tint used for the mTLS summary row and network badge. -->
    <!-- cert_present follows the brand accent; cert_missing stays red as a standard warning. -->
    <color name="cert_present">#FF8F00</color>
    <color name="cert_missing">#F44336</color>

    <!-- Frigate stats badges: each badge has a distinct muted tint so CPU/GPU are
         visually separable without colour-coded load alone. -->
    <color name="stats_cpu_text">#B0C4D8</color>
    <color name="stats_gpu_text">#C8B0D8</color>
</resources>
