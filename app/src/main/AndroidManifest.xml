<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
                     
    <!-- Nearby devices permission for Android 13+ and Android 16+ -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
                     android:usesPermissionFlags="neverForLocation" 
                     tools:targetApi="tiramisu" />
                     
    <!-- Pre-Tiramisu fallback for WiFi SSID detection. Android 13+ uses NEARBY_WIFI_DEVICES. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
                     android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"
                     android:maxSdkVersion="32" />

    <!-- Audio capture for Frigate two-way talk (speaker-on-camera intercom). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    
    <!-- Storage permission for downloads (not needed on Android 10+) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" 
                     android:maxSdkVersion="28" />
    
    <!-- Permission to install packages -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Notifications (runtime-requested on API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Lets the alert channel call setBypassDnd(true) so high-priority alerts cut
         through Do Not Disturb. The user must additionally grant DND access via
         Settings > Notifications > Do Not Disturb access. -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- Foreground service for the always-on alert listener.
         Using SPECIAL_USE because Android 14+ imposes a 6-hour cumulative daily cap on
         DATA_SYNC FGS — which killed the listener after a few hours of real use. A push-
         like Frigate WebSocket listener matches FOREGROUND_SERVICE_TYPE_SPECIAL_USE, with
         a subtype declared via <property> on the service. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"
                     tools:targetApi="34" />

    <!-- WakeLock keeps the CPU from freezing the OkHttp WS ping loop during doze. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Restart the alert listener after a reboot when the user has notifications enabled -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Prompt the user to exempt the alert listener from battery optimization,
         otherwise OEM doze/standby kills the foreground service unpredictably. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".FrigateViewerApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Freegate"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Freegate.NoActionBar"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
            <!-- Custom scheme handler -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="freegate" />
                <data android:scheme="frigate" />
            </intent-filter>
        </activity>
        
        <service
            android:name=".notifications.FrigateAlertService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Real-time notifications from a self-hosted Frigate NVR server via a persistent WebSocket (push-like listener)." />
        </service>

        <!-- Re-posts the persistent status notification if the user swipes it away
             on Android 14+, which made all FGS notifications dismissable by design. -->
        <receiver
            android:name=".notifications.StatusNotificationReviveReceiver"
            android:exported="false" />

        <!-- AlarmManager-scheduled revive: faster recovery path than the 15-min
             WorkManager watchdog. Fires every ~5min via setAndAllowWhileIdle, or
             immediately after onTaskRemoved. -->
        <receiver
            android:name=".notifications.ServiceReviveReceiver"
            android:exported="false" />

        <receiver
            android:name=".notifications.FrigateBootReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- FileProvider for sharing downloaded files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>